import sys as s

def garis():
    print("==============================================")

def garis_pinggir():
    print("=                                            =")

def judul():
    garis()
    garis_pinggir()
    print("=   Selamat Datang di Perpustakaan SMAN 3    =")
    garis_pinggir()
    garis()

def enter():
    print(" ")

def print_buku():
    print("= 1. Dasar-Dasar Pemrograman Python          =\n"
          "= 2. Algoritma dan Logika Berpikir           =\n"
          "= 3. Pengantar Ilmu Komputer                 =\n"
          "= 4. Matematika Diskrit untuk Pelajar        =\n"
          "= 5. Sistem Operasi dan Cara Kerjanya        =\n"
