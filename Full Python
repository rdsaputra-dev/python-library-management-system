          "= 9. Kecerdasan Buatan untuk Pemula          =\n"
          "= 10. C++ Sampai bisa                        ="
          )

def tunjuk_buku():
    enter()
    enter()
    garis()
    print("= Daftar Buku                                =")
    garis()
    print_buku()
    garis() 
    enter()

def tunjuk_buku_pinjam():
    enter()
    enter()
    garis()
    print("= Daftar buku yang dapat dipinjam            =")
    garis()
    print_buku()
    garis() 
    enter()

daftar_buku = [
          "Dasar-Dasar Pemrograman Python          =",
          "Algoritma dan Logika Berpikir           =",
          "Pengantar Ilmu Komputer                 =",
          "Matematika Diskrit untuk Pelajar        =",
          "Sistem Operasi dan Cara Kerjanya        =",
          "Jaringan Komputer Dasar                 =",
          "Struktur Data Sederhana                 =",
          "Keamanan Data dan Informasi             =",
          "Kecerdasan Buatan untuk Pemula          =",
          "C++ Sampai bisa                         =",
    ]

keranjang = []
 
def menu_perpus():
    garis()
    print("= MENU PERPUSTAKAAN                          =")
    garis()
    print("= 1. Lihat daftar buku                       =")
    print("= 2. Pinjam buku                             =")
    print("= 3. Lihat keranjang                         =")
    print("= 4. Kasir / Proses peminjaman               =")
    print("= 5. Keluar                                  =")
    garis()

def pilihan():
    garis()
    print("=      Silahkan pilih dalam bentuk angka     =")
    garis()

def pinjam():
    while True:
        tunjuk_buku_pinjam()

        try:
            pilih = int(input("Pilih nomor buku: "))

            if pilih < 1 or pilih > len(daftar_buku):
                print("Pilihan tidak valid.")
                input("Tekan ENTER untuk memilh ulang...")
                continue
            
            buku = daftar_buku[pilih - 1]

            if buku in keranjang:
                print("Buku sudah ada di keranjang.")
            else:
                keranjang.append(buku)
                print("Buku berhasil ditambahkan.")

        except ValueError:
            print("Tolong masukkan angka! ")
            continue

        lagi = input("Pilih buku lagi (y/t)? ")
        if lagi.lower() != "y":
            break
   
def lihat_keranjang():
    enter()
    enter()
    garis()
    print("=                 KERANJANG                  =")
    garis()
    garis_pinggir()

    if len(keranjang) == 0:
        print("= Keranjang masih kosong                     =")
    else:
        no = 1
        for buku in keranjang:
            print(f"= {no}. {buku}")
            no += 1
    garis_pinggir()
    garis()

def kasir():
    while True:
        enter()
        enter()
        garis()
        print("=                  KASIR                     =")
        garis()

        if len(keranjang) == 0:
            print("= Keranjang kosong, tidak ada buku         =")
            garis()
            input("Tekan ENTER untuk kembali...")
            return

        print("= Buku yang akan dipinjam:                   =")
        garis()
        garis_pinggir()
        no = 1
        for buku in keranjang:
            print(f"= {no}. {buku}")
            no += 1
        garis_pinggir()
        garis()
    
        konfirmasi = input("Konfirmasi peminjaman? (y/t): ")
        if konfirmasi.lower() == "y":
            keranjang.clear()
            enter()
            enter()
            garis()
            garis_pinggir()
            print("=           Peminjaman berhasil              =")
            garis_pinggir()
            garis()
            s.exit()
        elif konfirmasi.lower() == "t":
            enter()
            enter()
            garis()
            garis_pinggir()
            print("=           Peminjaman dibatalkan            =")
            garis_pinggir()
            garis()
            s.exit()
        else:
            print("Mohon konfirmasi dengan memilh y/t")
            input("Tekan ENTER untuk kembali...")
            continue

judul()

while True:
    enter()
    menu_perpus()
    enter()
    pilihan()
    try:
        answer = int(input("Pilihan Anda: "))
    except ValueError:
        print("Tolong masukkan angka tuan...")
        input("Tekan ENTER Untuk Kembali...")
        continue

    if answer == 1:
        tunjuk_buku()
        input("Tekan ENTER untuk kembali ke menu...")
    elif answer == 2:
        pinjam()
    elif answer == 3:
        lihat_keranjang()
        input("Tekan ENTER untuk kembali ke menu...")
    elif answer == 4:
        kasir()
    elif answer == 5:
        print("Terima kasih telah mengunjungi perpustakaan kami")
        break
    else:
        print("Pilihan tidak tersedia.")
        input("Tekan ENTER untuk kembali ke menu...")
